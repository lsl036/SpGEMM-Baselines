	$(AM_V_at)$(am__mv) libmtx/$(DEPDIR)/la-error.Tpo libmtx/$(DEPDIR)/la-error.Plo
#	$(AM_V_CC)source='libmtx/error.c' object='libmtx/la-error.lo' libtool=yes \
