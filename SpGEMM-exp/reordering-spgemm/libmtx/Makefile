manual/$(am__dirstamp):
	@$(MKDIR_P) manual
	@: > manual/$(am__dirstamp)

$(srcdir)/manual/libmtx.info: manual/libmtx.texi $(srcdir)/manual/version.texi $(manual_libmtx_TEXINFOS)
	$(AM_V_MAKEINFO)restore=: && backupdir="$(am__leading_dot)am$$$$" && \
	am__cwd=`pwd` && $(am__cd) $(srcdir) && \
	rm -rf $$backupdir && mkdir $$backupdir && \
	if ($(MAKEINFO) --version) >/dev/null 2>&1; then \
	  for f in $@ $@-[0-9] $@-[0-9][0-9] $(@:.info=).i[0-9] $(@:.info=).i[0-9][0-9]; do \
	    if test -f $$f; then mv $$f $$backupdir; restore=mv; else :; fi; \
	  done; \
	else :; fi && \
	cd "$$am__cwd"; \
	if $(MAKEINFO) $(AM_MAKEINFOFLAGS) $(MAKEINFOFLAGS) -I manual -I $(srcdir)/manual \
	 -o $@ $(srcdir)/manual/libmtx.texi; \
	then \
	  rc=0; \
	  $(am__cd) $(srcdir); \
	else \
	  rc=$$?; \
	  $(am__cd) $(srcdir) && \
	  $$restore $$backupdir/* `echo "./$@" | sed 's|[^/]*$$||'`; \
	fi; \
	rm -rf $$backupdir; exit $$rc

manual/libmtx.dvi: manual/libmtx.texi $(srcdir)/manual/version.texi $(manual_libmtx_TEXINFOS) manual/$(am__dirstamp)
	$(AM_V_TEXI2DVI)TEXINPUTS="$(am__TEXINFO_TEX_DIR)$(PATH_SEPARATOR)$$TEXINPUTS" \
	MAKEINFO='$(MAKEINFO) $(AM_MAKEINFOFLAGS) $(MAKEINFOFLAGS) -I manual -I $(srcdir)/manual' \
	$(TEXI2DVI) $(AM_V_texinfo) --build-dir=$(@:.dvi=.t2d) -o $@ $(AM_V_texidevnull) \
	`test -f 'manual/libmtx.texi' || echo '$(srcdir)/'`manual/libmtx.texi

manual/libmtx.pdf: manual/libmtx.texi $(srcdir)/manual/version.texi $(manual_libmtx_TEXINFOS) manual/$(am__dirstamp)
	$(AM_V_TEXI2PDF)TEXINPUTS="$(am__TEXINFO_TEX_DIR)$(PATH_SEPARATOR)$$TEXINPUTS" \
	MAKEINFO='$(MAKEINFO) $(AM_MAKEINFOFLAGS) $(MAKEINFOFLAGS) -I manual -I $(srcdir)/manual' \
	$(TEXI2PDF) $(AM_V_texinfo) --build-dir=$(@:.pdf=.t2p) -o $@ $(AM_V_texidevnull) \
	`test -f 'manual/libmtx.texi' || echo '$(srcdir)/'`manual/libmtx.texi

manual/libmtx.html: manual/libmtx.texi $(srcdir)/manual/version.texi $(manual_libmtx_TEXINFOS) manual/$(am__dirstamp)
	$(AM_V_MAKEINFO)rm -rf $(@:.html=.htp)
	$(AM_V_at)if $(MAKEINFOHTML) $(AM_MAKEINFOHTMLFLAGS) $(MAKEINFOFLAGS) -I manual -I $(srcdir)/manual \
	 -o $(@:.html=.htp) `test -f 'manual/libmtx.texi' || echo '$(srcdir)/'`manual/libmtx.texi; \
	then \
	  rm -rf $@ && mv $(@:.html=.htp) $@; \
	else \
	  rm -rf $(@:.html=.htp); exit 1; \
	fi
$(srcdir)/manual/version.texi:  $(srcdir)/manual/stamp-vti
$(srcdir)/manual/stamp-vti: manual/libmtx.texi $(top_srcdir)/configure
	@test -f manual/$(am__dirstamp) || $(MAKE) $(AM_MAKEFLAGS) manual/$(am__dirstamp)
	@(dir=.; test -f ./manual/libmtx.texi || dir=$(srcdir); \
	set `$(SHELL) $(top_srcdir)/build-aux/mdate-sh $$dir/manual/libmtx.texi`; \
	echo "@set UPDATED $$1 $$2 $$3"; \
	echo "@set UPDATED-MONTH $$2 $$3"; \
	echo "@set EDITION $(VERSION)"; \
	echo "@set VERSION $(VERSION)") > vti.tmp$$$$ && \
	(cmp -s vti.tmp$$$$ $(srcdir)/manual/version.texi \
	  || (echo "Updating $(srcdir)/manual/version.texi" && \
	      cp vti.tmp$$$$ $(srcdir)/manual/version.texi.tmp$$$$ && \
	      mv $(srcdir)/manual/version.texi.tmp$$$$ $(srcdir)/manual/version.texi)) && \
	rm -f vti.tmp$$$$ $(srcdir)/manual/version.texi.$$$$
	@cp $(srcdir)/manual/version.texi $@

mostlyclean-vti:
	-rm -f vti.tmp* $(srcdir)/manual/version.texi.tmp*

maintainer-clean-vti:
	-rm -f $(srcdir)/manual/stamp-vti $(srcdir)/manual/version.texi
