prefix=/usr/local
exec_prefix=${prefix}
libdir=${exec_prefix}/lib
includedir=${prefix}/include

Name: libmtx
Description: C library and utility programs for Matrix Market files
Version: 0.5.0
Libs: -L${libdir} -lmtx
Cflags: -I${includedir}  -DLIBMTX_HAVE_MPI -fopenmp -DLIBMTX_HAVE_LIBZ -DLIBMTX_HAVE_METIS
