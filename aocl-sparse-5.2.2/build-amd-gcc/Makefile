# Build rule for target.
sample_tcsr_dspmv: cmake_check_build_system
	$(MAKE) $(MAKESILENT) -f CMakeFiles/Makefile2 sample_tcsr_dspmv
.PHONY : sample_tcsr_dspmv

# fast build rule for target.
sample_tcsr_dspmv/fast:
	$(MAKE) $(MAKESILENT) -f tests/examples/CMakeFiles/sample_tcsr_dspmv.dir/build.make tests/examples/CMakeFiles/sample_tcsr_dspmv.dir/build
.PHONY : sample_tcsr_dspmv/fast

